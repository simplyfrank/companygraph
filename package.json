{
  "name": "companygraph",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "api",
    "pwa"
  ],
  "scripts": {
    "dev": "bash -c '. ./scripts/runtime-detect.sh && $COMPANYGRAPH_COMPOSE_CMD up -d neo4j postgres && ./scripts/wait-for-neo4j.sh && concurrently -k -n api,pwa \"cd api && bun run dev\" \"cd pwa && bun run dev\"'",
    "stop": "bash -c '. ./scripts/runtime-detect.sh && $COMPANYGRAPH_COMPOSE_CMD down'",
    "seed": "bun --cwd api scripts/seed.ts ../shared/seed/commercial-domain.json",
    "seed:saas-operator": "bun --cwd api scripts/seed-saas-operator.ts",
    "seed:saas-metric-library": "bun --cwd api scripts/seed-saas-metric-library.ts",
    "seed:funnel-pipeline": "bun --cwd api scripts/seed-funnel-pipeline.ts",
    "seed:marketing": "bun --cwd api scripts/seed-marketing.ts",
    "seed:sales": "bun --cwd api scripts/seed-sales.ts",
    "seed:platform-ops": "bun --cwd api scripts/seed-platform-ops-content.ts",
    "seed:product-delivery": "bun --cwd api scripts/seed-product-delivery.ts",
    "seed:customer-success": "bun --cwd api scripts/seed-customer-success.ts",
    "seed:finance-graph": "bun --cwd api scripts/seed-finance-graph.ts",
    "seed:finance-risks": "bun --cwd api scripts/seed-finance-risks.ts",
    "seed:enriched": "bun run scripts/seed-enriched.ts ./shared/seed/retail-mini-enriched.json",
    "schema:apply": "bun --cwd api run scripts/schema-apply.ts",
    "migrate:system-kind": "bun --cwd api scripts/migrate-system-kind.ts",
    "register:model": "bun --cwd api src/scripts/register-model-labels.ts",
    "register:story": "bun --cwd api src/scripts/register-story-labels.ts",
    "register:capability": "bun --cwd api src/scripts/register-capability-labels.ts",
    "register:kpi-impact": "bun --cwd api src/scripts/register-kpi-impact-edges.ts",
    "migrate:model": "bun --cwd api src/scripts/migrate-retail-to-model.ts",
    "typecheck": "bun build api/src/server.ts --target=bun --no-bundle > /dev/null && bun build pwa/src/main.tsx --target=browser --no-bundle > /dev/null",
    "test": "bash scripts/test-unit.sh",
    "test:integration": "bash scripts/test-integration.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "jose": "^5.6.0"
  }
}
