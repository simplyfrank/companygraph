{
  "name": "companygraph",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "api",
    "pwa"
  ],
  "scripts": {
    "dev": "bash -c '. ./scripts/runtime-detect.sh && $COMPANYGRAPH_COMPOSE_CMD up -d neo4j postgres && ./scripts/wait-for-neo4j.sh && concurrently -k -n api,pwa \"cd api && bun run dev\" \"cd pwa && bun run dev\"'",
    "stop": "bash -c '. ./scripts/runtime-detect.sh && $COMPANYGRAPH_COMPOSE_CMD down'",
    "seed": "bun --cwd api scripts/seed.ts ../shared/seed/commercial-domain.json",
    "seed:enriched": "bun run scripts/seed-enriched.ts ./shared/seed/retail-mini-enriched.json",
    "schema:apply": "bun --cwd api run scripts/schema-apply.ts",
    "migrate:system-kind": "bun --cwd api scripts/migrate-system-kind.ts",
    "register:model": "bun --cwd api src/scripts/register-model-labels.ts",
    "register:story": "bun --cwd api src/scripts/register-story-labels.ts",
    "migrate:model": "bun --cwd api src/scripts/migrate-retail-to-model.ts",
    "typecheck": "bun build api/src/server.ts --target=bun --no-bundle > /dev/null && bun build pwa/src/main.tsx --target=browser --no-bundle > /dev/null",
    "test": "bash scripts/test-unit.sh",
    "test:integration": "bash scripts/test-integration.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "jose": "^5.6.0"
  }
}
