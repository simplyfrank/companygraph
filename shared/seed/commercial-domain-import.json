  "edgeTypes": [
    {
      "name": "PART_OF",
      "description": "Entity belongs to a bounded context",
      "usage_example": "MATCH (e:Entity)-[:PART_OF]->(bc:BoundedContext)",
      "endpoints": [
        {
          "fromLabel": "Item",
          "toLabel": "BoundedContext",
          "cardinality": "MANY_TO_ONE"
        }
      ]
    },
    {
      "name": "UPSTREAM_OF",
      "description": "Bounded context provides data to another bounded context",
      "usage_example": "MATCH (bc1:BoundedContext)-[:UPSTREAM_OF]->(bc2:BoundedContext)",
      "endpoints": [
        {
          "fromLabel": "BoundedContext",
          "toLabel": "BoundedContext",
          "cardinality": "MANY_TO_MANY"
        }
      ]
    },
    {
      "name": "DOWNSTREAM_OF",
      "description": "Bounded context consumes data from another bounded context",
      "usage_example": "MATCH (bc1:BoundedContext)-[:DOWNSTREAM_OF]->(bc2:BoundedContext)",
      "endpoints": [
        {
          "fromLabel": "BoundedContext",
          "toLabel": "BoundedContext",
          "cardinality": "MANY_TO_MANY"
        }
      ]
    }
  ],

