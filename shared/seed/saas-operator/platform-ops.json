    { "label": "Activity", "id": "018f0200-0000-7000-8000-000000010102", "name": "Collect telemetry", "description": "Ingest metrics/logs/traces into the observability stack.", "attributes": { "seedKey": "platform-ops-act-obs-collect" } },
    { "label": "Activity", "id": "018f0200-0000-7000-8000-000000010103", "name": "Build dashboards", "description": "Compose fleet-health and per-tenant dashboards.", "attributes": { "seedKey": "platform-ops-act-obs-dashboards" } },
