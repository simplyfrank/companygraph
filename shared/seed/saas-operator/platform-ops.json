    { "label": "UserJourney", "id": "018f0200-0000-7000-8000-000000000001", "name": "Fleet observability", "description": "Metrics/logs/traces collection, dashboards, and alerting thresholds across the tenant fleet.", "attributes": { "seedKey": "platform-ops-journey-observability" } },
    { "label": "UserJourney", "id": "018f0200-0000-7000-8000-000000000002", "name": "Deploy / release", "description": "CI artifact to staging to canary to production rollout, with rollback.", "attributes": { "seedKey": "platform-ops-journey-deploy" } },
