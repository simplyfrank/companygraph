# Neo4j credentials.
# Important: Neo4j refuses the literal "neo4j" as a password — pick anything
# else, but the value MUST match between this file and docker-compose.yml
# (which reads ${NEO4J_USER}/${NEO4J_PASSWORD} via interpolation).
NEO4J_USER=neo4j
NEO4J_PASSWORD=companygraph_dev
NEO4J_URI=bolt://127.0.0.1:7687

# API server binding.
# Defaults to loopback per NFR-02 ("API server binds to 127.0.0.1 only by
# default; no exposure beyond localhost without explicit HOST= override").
HOST=127.0.0.1
API_PORT=8787

# chat-interface (rev 3.1).
# Anthropic API key for the agent's LLM. If unset, the chat server boots in
# degraded mode using MockLLMClient (envelope carries `degraded: 'mock_llm'`).
ANTHROPIC_API_KEY=
# SQLite path for chat persistence (conversations, messages, quota, bookmarks).
# Relative paths are resolved from the api/ workspace cwd at boot.
CHAT_DB_PATH=../data/chat.db

# cto-analytics-reporting (FR-10, DD-06 / NFR-R1).
# SQLite path for the analytics precompute cache + settings — an ISOLATED file,
# separate from the chat DB, holding the nightly run snapshots, journey/system/
# AI score tables, alerts, and the tunable settings row + audit trail.
# Relative paths are resolved from the api/ workspace cwd at boot.
ANALYTICS_DB_PATH=./data/analytics.sqlite

# Postgres (adopted 2026-07-04, _baseline FR-06) — system of record for
# change-requests, risk-register, kpi-measurements, sla-breaches.
# docker-compose brings up the `postgres` service; migrations live in
# api/src/storage/postgres/.
POSTGRES_URI=postgresql://companygraph:companygraph_dev@127.0.0.1:5432/companygraph

# OneLogin OAuth (adopted 2026-07-04, _baseline FR-05).
# When ONELOGIN_ISSUER is set, JWTs are signature-verified via jose+JWKS.
# When unset, the API runs a DEV-ONLY fallback that skips signature
# verification — never deploy beyond localhost without an issuer.
ONELOGIN_ISSUER=
ONELOGIN_CLIENT_ID=
ONELOGIN_CLIENT_SECRET=
ONELOGIN_REDIRECT_URI=

# ontology-manager — audit log retention (FR-13a).
# 365 = archive audit rows older than 365 days into
#   data/ontology-manager/audit-archive/YYYY-MM.jsonl.gz daily.
# 0   = disable archiving (rows live forever in _OntologyAudit; the
#       _OntologyEvent 5-min purge still runs unconditionally).
OPT_ONTOLOGY_AUDIT_RETENTION_DAYS=365
# Cron expression in the operator's TZ. Default: 03:00 daily.
OPT_ONTOLOGY_AUDIT_CRON="0 3 * * *"
