# Neo4j credentials.
# Important: Neo4j refuses the literal "neo4j" as a password — pick anything
# else, but the value MUST match between this file and docker-compose.yml
# (which reads ${NEO4J_USER}/${NEO4J_PASSWORD} via interpolation).
NEO4J_USER=neo4j
NEO4J_PASSWORD=companygraph_dev
NEO4J_URI=bolt://127.0.0.1:7687

# API server binding.
# Defaults to loopback per NFR-02 ("API server binds to 127.0.0.1 only by
# default; no exposure beyond localhost without explicit HOST= override").
HOST=127.0.0.1
API_PORT=8787

# ontology-manager — audit log retention (FR-13a).
# 365 = archive audit rows older than 365 days into
#   data/ontology-manager/audit-archive/YYYY-MM.jsonl.gz daily.
# 0   = disable archiving (rows live forever in _OntologyAudit; the
#       _OntologyEvent 5-min purge still runs unconditionally).
OPT_ONTOLOGY_AUDIT_RETENTION_DAYS=365
# Cron expression in the operator's TZ. Default: 03:00 daily.
OPT_ONTOLOGY_AUDIT_CRON="0 3 * * *"
